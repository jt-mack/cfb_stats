{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "allowJs": true,
  },
  "include": ["server.ts", "seeds/**/*.ts", "routes/**/*.ts"], 
  "exclude": ["node_modules", "client"]
}
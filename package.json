{
  "name": "cfb_stats",
  "version": "1.0.0",
  "main": "server.js",
  "author": "Josh McCormick",
  "license": "MIT",
  "engines": {
    "node": ">=16.13.0",
    "yarn": ">=v1.22.19"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "cfbd": "^5.13.2",
    "concurrently": "^7.5.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "if-env": "^1.0.4",
    "node-cache": "^5.1.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "nodemon": "^2.0.20",
    "response-time": "^2.3.2",
    "tsx": "^4.21.0"
  },
  "scripts": {
    "start": "if-env NODE_ENV=production && npm run start:prod || npm run start:dev",
    "start:prod": "concurrently \"node dist/server.js\" \"cd client-next && PORT=3000 npm run start\"",
    "start:dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "server:dev": "tsx watch server.ts --ignore 'client/*'",
    "client": "cd client-next && npm run dev",
    "build": "npm run build:server && (cd client-next && npm install && npm run build)",
    "build:server": "tsc",
    "build:client": "cd client-next && npm run build",
    "heroku-postbuild": "npm run build"
  }
}
